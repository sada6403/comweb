# Copy to ".env" and fill in. The .env file is gitignored.

# Admin login credentials (checked by POST /api/login)
ADMIN_EMAIL=admin@northflow.dev
ADMIN_PASSWORD=change-me

# Secret used to sign admin JWTs — use a long random string in production
JWT_SECRET=replace-with-a-long-random-secret

# Port for the Express API / production server (optional, defaults to 3000)
PORT=3000
